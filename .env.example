# QRIE local environment template
# START_SIMPLE.bat can bootstrap a real .env from these settings.

# Frontend / proxy
VITE_API_BASE_URL=
VITE_DATA_API_BASE_URL=/api
VITE_PORT=5173
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:3000

# API ports
SCANNER_API_PORT=8000
DATABASE_API_PORT=8001
REPORT_API_PORT=8002

# PostgreSQL connection used by the Python APIs
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=qrie_platform
DB_USER=qrie_app
DB_PASSWORD=replace-with-generated-secret
DB_SSL_MODE=require
DB_ECHO=false

# Local development fallback when Docker/Postgres is unavailable or has stale credentials
USE_SQLITE=false
SQLITE_PATH=.local/qrie_local.sqlite3
ALLOW_SQLITE_FALLBACK=true

# Dockerized PostgreSQL container settings
POSTGRES_DB=qrie_platform
POSTGRES_USER=qrie_app
POSTGRES_PASSWORD=replace-with-generated-secret

# Application-layer encryption key for encrypted JSON fields
FIELD_ENCRYPTION_KEY=replace-with-generated-fernet-key

# Optional pgAdmin profile
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=replace-with-generated-secret

# Scanner API security defaults
ALLOW_INTERNAL_SCAN=false
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60

# Optional AI chatbot powered by the NVIDIA API
NVIDIA_API_KEY=
NVIDIA_CHAT_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
