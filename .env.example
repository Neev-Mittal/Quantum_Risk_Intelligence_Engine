# QRIE Platform - Environment Configuration
# Copy this to .env.local and update with your actual values

# ─────────────────────────────────────────────────────────────────────────────
# Frontend Configuration
# ─────────────────────────────────────────────────────────────────────────────

# API Base URL (for frontend to call backend)
VITE_API_BASE_URL=http://localhost:8001

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL Database Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Database Host (default: localhost for local development)
DB_HOST=localhost

# Database Port (default PostgreSQL port: 5432)
DB_PORT=5432

# Database Name
DB_NAME=qrie_platform

# Database User (default: postgres)
DB_USER=postgres

# Database Password (IMPORTANT: Change from default in production!)
DB_PASSWORD=postgres

# SQLAlchemy Echo (log SQL queries - true/false)
DB_ECHO=false

# ─────────────────────────────────────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Scanner API Port
SCANNER_API_PORT=8000

# Database API Port
DATABASE_API_PORT=8001

# Frontend Dev Server Port
VITE_PORT=5173

# ─────────────────────────────────────────────────────────────────────────────
# Docker Configuration (if using containers)
# ─────────────────────────────────────────────────────────────────────────────

# Docker Compose Services
# Uncomment and set if using Docker
# COMPOSE_PROJECT_NAME=qrie-platform
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=qrie_platform
